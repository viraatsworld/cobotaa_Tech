          <param name="max">0.310886</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${namespace}joint_3">
        <command_interface name="position">
          <param name="min">-2.617994</param>
          <param name="max">2.617994</param>
        </command_interface>

        <command_interface name="acceleration">
          <param name="min">-0.621773</param>
          <param name="max">0.621773</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${namespace}joint_4">
        <command_interface name="position">
          <param name="min">-4.712389</param>
          <param name="max">4.712389</param>
        </command_interface>
        <command_interface name="acceleration">
          <param name="min">-0.049741</param>
          <param name="max">0.049741</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${namespace}joint_5">
        <command_interface name="position">
          <param name="min">-2.617994</param>
          <param name="max">2.617994</param>
        </command_interface>
        <command_interface name="acceleration">
          <param name="min">-0.690860</param>
          <param name="max">0.690860</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${namespace}joint_6">
        <command_interface name="position">
          <param name="min">-6.283185</param>
          <param name="max">6.283185</param>
        </command_interface>
        <command_interface name="acceleration">
          <param name="min">-0.690860</param>
          <param name="max">0.690860</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
    </ros2_control>
  </xacro:macro>
</robot>
